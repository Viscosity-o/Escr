# ──────────────────────────────────────────────
# Global Intelligence Layer — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# Application environment: development | staging | production
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Collector Settings ─────────────────────────
# Default HTTP request timeout in seconds
COLLECTOR_HTTP_TIMEOUT_SECONDS=30

# Maximum retry attempts for failed requests
COLLECTOR_MAX_RETRIES=3

# Delay between retries in seconds
COLLECTOR_RETRY_BACKOFF_SECONDS=5

# ── Publisher / Forwarding Settings ───────────
# Target endpoint where normalized data is forwarded
# (Technology-agnostic placeholder — fill with queue URL, webhook, etc.)
PUBLISHER_TARGET_ENDPOINT=

# ── Storage Settings ──────────────────────────
# Directory used for transient/staging file storage
STORAGE_STAGING_DIR=storage/staging

# ── Secrets (never hardcode — always use env vars) ──
# Example API key placeholders — add real source-specific keys here
NEWSAPI_KEY=14f73915550849d5a98786f502d32656
# MARITIME_API_KEY=
# SANCTIONS_API_KEY=
# COMMODITY_API_KEY=
